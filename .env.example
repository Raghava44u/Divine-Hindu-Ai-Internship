# Environment Configuration
PROJECT_NAME="Divine Hindu CRM"
API_V1_STR="/api/v1"

# Security
SECRET_KEY="replace_me_with_a_secure_random_string_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL="mysql+pymysql://crm_user:crm_password@localhost:3306/divine_hindu_crm"

# Redis & Celery
REDIS_URL="redis://localhost:6379/0"

# Email Configuration (SMTP)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST="smtp.gmail.com"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
EMAILS_FROM_EMAIL="info@divinehindu.com"
EMAILS_FROM_NAME="Divine Hindu CRM"
